# Database connection string (URL-encode special characters in the password, e.g. @ becomes %40)
DATABASE_URL=postgresql://username:password@localhost:5432/database_name

# JWT Secret Key for signing session/auth tokens
JWT_SECRET_KEY=your_jwt_secret_key_here

# 32-character encryption key for symmetric data encryption
ENCRYPTION_KEY=your_32_character_key_here______

# Flask configuration settings
FLASK_APP=app
FLASK_ENV=development
FLASK_DEBUG=1
